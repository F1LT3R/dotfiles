#!/bin/bash

# Ensure the directory exists
DIR="$HOME/Notes/"
mkdir -p "$DIR"

# Create the file name with the current date and time
FILE="Note_$(date +%Y-%m-%d_%H-%M-%S).md"
FILEPATH="$DIR/$FILE"

# Write the initial content to the file
echo "# Note $(date +%Y/%m/%d) $(date +%H:%M:%S)

" > "$FILEPATH"

code $FILEPATH