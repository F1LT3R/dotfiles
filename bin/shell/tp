#!/usr/bin/env bash
# tp — tmux pick: fzf session picker with window focus
#
# Usage: tp
#
# Scans all tmux server sockets, shows styled sessions
# in fzf, and focuses the selected session's window.
#
# Window manager: AppleScript/iTerm2 (macOS),
#                 bspwm+wmctrl (Linux)

source ~/bin/system/detect-os-mode 2>/dev/null

# Scan all tmux server sockets for sessions
SOCKET_DIR="/tmp/tmux-$(id -u)"
declare -a KEYS DIRS PNAMES PIDXS TPIDS
N=0
MAX_DIR=0
MAX_PNAME=0

if [ -d "$SOCKET_DIR" ]; then
    for sock in "$SOCKET_DIR"/*; do
        [ -S "$sock" ] || continue
        SNAME=$(basename "$sock")
        while IFS= read -r sess; do
            case "$sess" in
                agents-*) continue ;;
            esac

            # Check if ANY pane has a styled title
            STYLED_PANE=""
            while IFS= read -r ptitle; do
                case "$ptitle" in
                    📁*) STYLED_PANE="$ptitle"; break ;;
                esac
            done < <(tmux -L "$SNAME" list-panes \
                -t "$sess" \
                -F '#{pane_title}' 2>/dev/null)
            [ -z "$STYLED_PANE" ] && continue

            PDIR=$(tmux -L "$SNAME" \
                display-message -t "$sess" \
                -p '#{pane_current_path}' \
                2>/dev/null)
            D=$(basename "$PDIR" 2>/dev/null)
            P=$(tmux -L "$SNAME" \
                display-message -t "$sess" \
                -p '#{@pane_name}' 2>/dev/null)
            IX=$(tmux -L "$SNAME" \
                display-message -t "$sess" \
                -p '#{window_index}.#{pane_index}' \
                2>/dev/null)
            TP=$(tmux -L "$SNAME" \
                display-message -t "$sess" \
                -p '#{pane_pid}' 2>/dev/null)

            KEYS[$N]="${SNAME}/${sess}"
            DIRS[$N]="$D"
            PNAMES[$N]="$P"
            PIDXS[$N]="$IX"
            TPIDS[$N]="$TP"

            [ ${#D} -gt $MAX_DIR ] && \
                MAX_DIR=${#D}
            [ ${#P} -gt $MAX_PNAME ] && \
                MAX_PNAME=${#P}
            N=$((N + 1))
        done < <(tmux -L "$SNAME" \
            list-sessions \
            -F '#{session_name}' 2>/dev/null)
    done
fi

if [ "$N" -eq 0 ]; then
    echo "No styled sessions found."
    exit 0
fi

# Build aligned entries
ENTRIES=""
for i in $(seq 0 $((N - 1))); do
    LINE=$(printf \
        "📁 %-${MAX_DIR}s  🖥  %-${MAX_PNAME}s [%s]  🆔 %s" \
        "${DIRS[$i]}" "${PNAMES[$i]}" \
        "${PIDXS[$i]}" "${TPIDS[$i]}")
    ENTRIES+="${KEYS[$i]}$(printf '\t')${LINE}"
    ENTRIES+=$'\n'
done

SELECTED=$(printf '%s' "$ENTRIES" | fzf \
    --no-sort \
    --layout=reverse \
    --prompt='tp> ' \
    --with-nth=2.. \
    --delimiter=$'\t' \
    | cut -f1)

[ -z "$SELECTED" ] && exit 0

# Extract server and session from SERVER/SESSION
SELECTED_SERVER="${SELECTED%%/*}"
SELECTED_SESSION="${SELECTED#*/}"

# Get the active pane's title for window matching
TITLE=$(tmux -L "$SELECTED_SERVER" \
    display-message -t "$SELECTED_SESSION" \
    -p '#{pane_title}')

_focus_macos() {
    # Match iTerm2 window by title via AppleScript
    osascript -e "
        tell application \"iTerm2\"
            set t to \"$TITLE\"
            repeat with w in every window
                if name of w is t then
                    select w
                    activate
                    return
                end if
            end repeat
        end tell
    " 2>/dev/null && return 0
    return 1
}

_focus_bspwm() {
    local wid
    wid=$(wmctrl -l 2>/dev/null \
        | grep -F "$TITLE" \
        | awk '{print $1}' \
        | head -1)
    if [ -n "$wid" ]; then
        bspc node "$wid" -f
        return 0
    fi
    return 1
}

case "$OS_MODE" in
    MACOS)  _focus_macos ;;
    *)      _focus_bspwm ;;
esac

if [ $? -ne 0 ]; then
    echo "Could not find window for: \
$SELECTED_SESSION"
fi
