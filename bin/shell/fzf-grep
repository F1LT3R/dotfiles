#!/usr/bin/env bash
# fzf + ripgrep live grep → vim at match
dir=$(pwd)
title=" 🔍 ripgrep: ${dir/#$HOME/\~} "

sel=$(rg --color=always --line-number \
  --no-heading --smart-case "" |
  fzf --no-mouse --ansi --reverse \
    --delimiter : \
    --header "$title" \
    --preview 'rg --color=always \
      --context 5 {q} {1}' \
    --preview-window 'up:5:wrap' \
    --bind 'change:reload:rg --color=always \
      --line-number --no-heading \
      --smart-case {q} || true' \
    --phony --query "")

[ -n "$sel" ] || exit 0

file=$(echo "$sel" | cut -d: -f1)
line=$(echo "$sel" | cut -d: -f2)

# Open vim in a new iTerm2 window (not inside tmux)
# Escape double quotes for osascript strings
safe_dir="$(echo "$dir" | sed 's/"/\\\\\\"/g')"
safe_file="$(echo "$file" | sed 's/"/\\\\\\"/g')"
safe_line="$(echo "$line" | sed 's/"/\\\\\\"/g')"
osascript -e 'tell application "iTerm2"' \
  -e 'activate' \
  -e 'set newWindow to (create window with default profile)' \
  -e 'tell current session of newWindow' \
  -e "write text \"cd '$safe_dir' && clear && vim +'$safe_line' '$safe_file'\"" \
  -e 'end tell' \
  -e 'end tell'
