#!/usr/bin/env bash
# unichar — convert ASCII to Unicode styled glyphs
#
# Usage: unichar [-f font] [text...]
#        echo "text" | unichar [-f font]
#
# Fonts: sansbold (default), super, blocks
# Unmapped characters pass through unchanged.

FONT="sansbold"
while getopts "f:" opt; do
    case $opt in
        f) FONT="$OPTARG" ;;
        *)
            echo "Usage: unichar [-f font] [text...]" >&2
            exit 1
            ;;
    esac
done
shift $((OPTIND - 1))

declare -A G

# --- sansbold (Mathematical Bold Sans-Serif) ---
G[sansbold:A]=𝗔 G[sansbold:B]=𝗕 G[sansbold:C]=𝗖
G[sansbold:D]=𝗗 G[sansbold:E]=𝗘 G[sansbold:F]=𝗙
G[sansbold:G]=𝗚 G[sansbold:H]=𝗛 G[sansbold:I]=𝗜
G[sansbold:J]=𝗝 G[sansbold:K]=𝗞 G[sansbold:L]=𝗟
G[sansbold:M]=𝗠 G[sansbold:N]=𝗡 G[sansbold:O]=𝗢
G[sansbold:P]=𝗣 G[sansbold:Q]=𝗤 G[sansbold:R]=𝗥
