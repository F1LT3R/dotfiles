G[sansbold:m]=𝗺 G[sansbold:n]=𝗻 G[sansbold:o]=𝗼
G[sansbold:p]=𝗽 G[sansbold:q]=𝗾 G[sansbold:r]=𝗿
G[sansbold:s]=𝘀 G[sansbold:t]=𝘁 G[sansbold:u]=𝘂
G[sansbold:v]=𝘃 G[sansbold:w]=𝘄 G[sansbold:x]=𝘅
G[sansbold:y]=𝘆 G[sansbold:z]=𝘇
G[sansbold:0]=𝟬 G[sansbold:1]=𝟭 G[sansbold:2]=𝟮
G[sansbold:3]=𝟯 G[sansbold:4]=𝟰 G[sansbold:5]=𝟱
G[sansbold:6]=𝟲 G[sansbold:7]=𝟳 G[sansbold:8]=𝟴
G[sansbold:9]=𝟵

# --- super (superscript) ---
G[super:0]=⁰ G[super:1]=¹ G[super:2]=²
G[super:3]=³ G[super:4]=⁴ G[super:5]=⁵
G[super:6]=⁶ G[super:7]=⁷ G[super:8]=⁸
G[super:9]=⁹ G[super:(]=⁽ G[super:)]=⁾
G[super:.]=· G[super:-]=⁻ G[super:+]=⁺

# --- blocks (negative squared) ---
G[blocks:A]=🅰 G[blocks:B]=🅱 G[blocks:C]=🅲
G[blocks:D]=🅳 G[blocks:E]=🅴 G[blocks:F]=🅵
G[blocks:G]=🅶 G[blocks:H]=🅷 G[blocks:I]=🅸
