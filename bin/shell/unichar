G[blocks:y]=🆈 G[blocks:z]=🆉

_convert() {
    local input="$1" output=""
    local i c
    for ((i=0; i<${#input}; i++)); do
        c="${input:i:1}"
        output+="${G[${FONT}:${c}]:-$c}"
    done
    printf '%s' "$output"
}

if [ $# -gt 0 ]; then
    _convert "$*"
    echo
else
    while IFS= read -r line || [ -n "$line" ]; do
        _convert "$line"
        echo
    done
fi
