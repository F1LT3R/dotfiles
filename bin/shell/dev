#!/bin/bash
DIR="${1:-$(pwd)}"
DIR="$(cd "$DIR" && pwd)"
SESSION="claude-$$"

osascript <<EOF
tell application "iTerm2"
    create window with default profile
    
    tell current window
        select
    end tell
end tell

tell application "System Events"
    tell process "iTerm2"
        click menu item "Zoom" of menu "Window" of menu bar 1
    end tell
end tell

delay 0.5

tell application "iTerm2"
    tell current tab of current window
        tell session 1
            split vertically with default profile
        end tell
        
        tell session 2
            split horizontally with default profile
        end tell
        
        tell session 1
            split horizontally with default profile
        end tell
    end tell
    
    delay 0.5
    
    tell current tab of current window
        tell session 1
            set transparency to 0.2
            set background color to {8000, 1000, 4000, 65535}
            write text "cd '$DIR' && tmux new-session -s $SESSION 'claude --resume 2>/dev/null || claude'"
        end tell
        tell session 3
            set transparency to 0.2
            set background color to {1500, 1000, 10000, 65535}
            write text "cd '$DIR' && agent-notify"
        end tell
        tell session 2
            set transparency to 0.2
            set background color to {2000, 500, 3000, 65535}
            write text "cd '$DIR' && source ~/.secrets/llms/OPENROUTER_API_KEY && ssh-f1lt3r && clear && ll"
        end tell
        tell session 4
            set transparency to 0.2
            set background color to {3500, 1500, 6500, 65535}
            write text "cd '$DIR' && fstop"
        end tell
    end tell
end tell
EOF