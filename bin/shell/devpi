#!/usr/bin/env bash

# Parse flags
SHARED=0
LAUNCHED=0
while getopts "sL" opt; do
    case $opt in
        s) SHARED=1 ;;
        L) LAUNCHED=1 ;;
        *) echo "Usage: devpi [-s] [path]"; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

DIR="${1:-$(pwd)}"
DIR="$(cd "$DIR" && pwd)"
DIRNAME="$(basename "$DIR")"
SERVER="$DIRNAME"

if [ "$SHARED" = "1" ]; then
    OUTER="devpi-${DIRNAME}"
else
    OUTER="devpi-${DIRNAME}-$$"
fi

# Open in a new maximized terminal window (desktop)
# or unset TMUX and continue (SSH/headless)
if [ "$LAUNCHED" != "1" ]; then
    SFLAG=""
    [ "$SHARED" = "1" ] && SFLAG="-s "

    if [ -n "$SSH_TTY" ] || \
       [ "$OS_MODE" != "MACOS" -a -z "$DISPLAY" ]; then
        # SSH/headless: run directly, unset TMUX
        [ -n "$TMUX" ] && unset TMUX
    else
        # Desktop: new maximized window
        tmux-window \
            "exec env TL_READY=1 devpi -L ${SFLAG}'$DIR'"
        exit 0
    fi
fi

# Only sleep in desktop mode (window animation)
if [ -z "$SSH_TTY" ]; then
    sleep 0.5
fi

# Calculate pane sizes (percentages of terminal)
# в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
# в”Ӯ             в”Ӯ 1 pi-deepseek 56%  в”Ӯ 2 pi-qwen 44%   в”Ӯ
# в”Ӯ 0 fstop 21% в”Ӯ           h:70% topв”Ӯ        h:70% topв”Ӯ
# в”Ӯ       h:100%в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
# в”Ӯ             в”Ӯ 3 terminal                           в”Ӯ
# в”Ӯ             в”Ӯ                       h:30% bottom   в”Ӯ
# в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
COLS=$(tput cols)
ROWS=$(tput lines)
COL1=$(( COLS * 21 / 100 ))
RIGHT_COLS=$(( COLS - COL1 - 1 ))
COL_PI1=$(( RIGHT_COLS * 56 / 100 ))
ROW_PI=$(( ROWS * 70 / 100 ))

# Shared mode: if session exists, create grouped
# session and attach
if [ "$SHARED" = "1" ] && \
   tmux -L "$SERVER" has-session \
       -t "$OUTER" 2>/dev/null; then
    GRP="${OUTER}-$$"
    tmux -L "$SERVER" new-session -d \
        -t "$OUTER" -s "$GRP"
    tmux -L "$SERVER" select-pane \
        -t "${GRP}:0.1"
    ( sleep 1 && \
      tmux -L "$SERVER" resize-pane \
          -t "${OUTER}:0.0" -x "$COL1" && \
      tmux -L "$SERVER" resize-pane \
          -t "${OUTER}:0.1" -y "$ROW_PI" && \
      tmux -L "$SERVER" resize-pane \
          -t "${OUTER}:0.1" -x "$COL_PI1" \
    ) &
    if [ -n "$SSH_TTY" ]; then
        tmux -L "$SERVER" attach -t "$GRP"
        echo "Detached. Reattach: \
tmux -L $SERVER attach -t $GRP"
    else
        exec tmux -L "$SERVER" \
            attach -t "$GRP"
    fi
fi

# Create session with pane 0 (force full terminal size)
tmux -L "$SERVER" new-session -d \
    -s "$OUTER" -c "$DIR" \
    -x "$COLS" -y "$ROWS" \
    -e "TERM=screen-256color"

# Load mouse/copy bindings into this isolated server so dragвҶ’pbcopy works
tmux -L "$SERVER" source-file ~/.tmux.conf 2>/dev/null || true

# Enable mouse for wheel-scrollback + per-pane selection.
# Without this, multi-pane tmux relies on terminal-native selection
# which spans pane borders and bypasses tmux scrollback.
tmux -L "$SERVER" set-option -g mouse on
# set-clipboard=on (not 'external') is required so tmux's own copy
# commands emit OSC 52 вҖ” works locally and over SSH. The terminal app
# must allow OSC 52 writes (iTerm2: General > Selection > Applications
# in terminal may access clipboard).
tmux -L "$SERVER" set-option -g set-clipboard on
# Drag-end copies via OSC 52. -no-clear keeps the selection visible
# and keeps you scrolled in place, like text selection in a document.
tmux -L "$SERVER" bind -T copy-mode-vi MouseDragEnd1Pane \
    send -X copy-selection-no-clear

# Shared mode: set window-size and resize hook
if [ "$SHARED" = "1" ]; then
    tmux -L "$SERVER" set-option \
        -t "$OUTER" window-size latest
    HOOK='W=#{window_width}; H=#{window_height}; '
    HOOK+="tmux -L ${SERVER} resize-pane"
    HOOK+=" -t ${OUTER}:0.0"
    HOOK+=" -x \$((W*21/100)); "
    HOOK+="tmux -L ${SERVER} resize-pane"
    HOOK+=" -t ${OUTER}:0.1"
    HOOK+=" -y \$((H*70/100)); "
    HOOK+="tmux -L ${SERVER} resize-pane"
    HOOK+=" -t ${OUTER}:0.1"
    HOOK+=" -x \$(((W-W*21/100-1)*56/100))"
    tmux -L "$SERVER" set-hook -t "$OUTER" \
        after-resize-window "run-shell '$HOOK'"
fi

# Split pane 0 horizontally вҶ’ 0 | 1
tmux -L "$SERVER" split-window \
    -t "$OUTER:0.0" -h -c "$DIR"

# Split pane 1 vertically вҶ’ 0 | 1 (top), 2 (bottom, spans right area)
tmux -L "$SERVER" split-window \
    -t "$OUTER:0.1" -v -c "$DIR"

# Split pane 1 horizontally вҶ’ 0 | 1 (top-left), 3 (top-right), 2 (bottom)
tmux -L "$SERVER" split-window \
    -t "$OUTER:0.1" -h -c "$DIR"

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Layout (tmux renumbers panes in layout-walk order
# after splits: leftвҶ’right, topвҶ’bottom):
#   pane 0 (col1, full height)
#   pane 1 (top-left of right)  в”Ӯ  pane 2 (top-right of right)
#   pane 3 (bottom, spans right area)
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Start programs in each pane
tmux -L "$SERVER" send-keys -t "$OUTER:0.0" \
    "cd '$DIR' && fstop" Enter
tmux -L "$SERVER" send-keys -t "$OUTER:0.1" \
    "pi --model 'deepseek-v4-flash'" Enter
tmux -L "$SERVER" send-keys -t "$OUTER:0.2" \
    "pi --model 'qwen-coder'" Enter
tmux -L "$SERVER" send-keys -t "$OUTER:0.3" \
    "cd '$DIR' && clear && ll" Enter

# Format pane titles
# рҹ“Ғ рқ——рқ—ңрқ—Ҙ  рҹ–Ҙ  рқ—Ўрқ—”рқ— рқ—ҳ [рқҹ¬.рқҹ¬]  рҹҶ” рқҹӯрқҹ®рқҹҜрқҹ°рқҹұ
DIR_UPPER=$(echo "$DIRNAME" | \
    tr '[:lower:]' '[:upper:]')
BOLD_DIR=$(unichar "$DIR_UPPER")
BOLD_PID=$(unichar "$$")

_fmt_pane_title() {
    local name="$1" idx="$2"
    local bold_name bold_idx
    bold_name=$(echo "$name" | \
        tr '[:lower:]' '[:upper:]' | unichar)
    bold_idx=$(unichar "[$idx]")
    printf 'рҹ“Ғ %s  рҹ–Ҙ  %s %s  рҹҶ” %s' \
        "$BOLD_DIR" "$bold_name" \
        "$bold_idx" "$BOLD_PID"
}

_set_pane() {
    local target="$1" name="$2" idx="$3"
    local styled="$(_fmt_pane_title "$name" "$idx")"
    tmux -L "$SERVER" select-pane \
        -t "$target" \
        -T "$styled"
    tmux -L "$SERVER" set-option -p \
        -t "$target" @pane_name "$name"
    tmux -L "$SERVER" set-option -p \
        -t "$target" @pane_styled_title "$styled"
}

_set_pane "$OUTER:0.0" "fstop"        "0.0"
_set_pane "$OUTER:0.1" "pi-deepseek"  "0.1"
_set_pane "$OUTER:0.2" "pi-qwen"      "0.2"
_set_pane "$OUTER:0.3" "terminal"     "0.3"

# Set pane background colors
tmux -L "$SERVER" select-pane \
    -t "$OUTER:0.0" -P 'bg=#0b0514'  # fstop
tmux -L "$SERVER" select-pane \
    -t "$OUTER:0.1" -P 'bg=#1f0410'  # pi-deepseek
tmux -L "$SERVER" select-pane \
    -t "$OUTER:0.2" -P 'bg=#0e002a'  # pi-qwen
tmux -L "$SERVER" select-pane \
    -t "$OUTER:0.3" -P 'bg=#08020c'  # terminal

tmux -L "$SERVER" select-pane -t "$OUTER:0.1"

# Resize after attach (hooks don't resolve
# pane targets properly)
( sleep 1 && \
  tmux -L "$SERVER" resize-pane \
      -t "${OUTER}:0.0" -x "$COL1" && \
  tmux -L "$SERVER" resize-pane \
      -t "${OUTER}:0.1" -y "$ROW_PI" && \
  tmux -L "$SERVER" resize-pane \
      -t "${OUTER}:0.1" -x "$COL_PI1" \
) &

# Ephemeral: clean up session on detach/close
if [ "$SHARED" != "1" ]; then
    trap "tmux -L '$SERVER' kill-session \
        -t '$OUTER' 2>/dev/null" \
        EXIT HUP TERM
fi

if [ -n "$SSH_TTY" ]; then
    tmux -L "$SERVER" attach -t "$OUTER"
    if [ "$SHARED" = "1" ]; then
        echo "Detached. Reattach: \
tmux -L $SERVER attach -t $OUTER"
    fi
else
    if [ "$SHARED" = "1" ]; then
        exec tmux -L "$SERVER" \
            attach -t "$OUTER"
    else
        tmux -L "$SERVER" attach -t "$OUTER"
    fi
fi
