#!/usr/bin/env bash
# tclean — kill all unattached tmux sessions
# across all servers

KILLED=0
SOCKET_DIR="/tmp/tmux-$(id -u)"

if [ ! -d "$SOCKET_DIR" ]; then
    echo "No tmux sockets found."
    exit 0
fi

for sock in "$SOCKET_DIR"/*; do
    [ -S "$sock" ] || continue
    SNAME=$(basename "$sock")
    while read -r name attached; do
        if [ "$attached" = "0" ]; then
            tmux -L "$SNAME" kill-session \
                -t "$name" 2>/dev/null
            echo "killed: $name (server: $SNAME)"
            KILLED=$((KILLED + 1))
        fi
    done < <(tmux -L "$SNAME" list-sessions -F \
        '#{session_name} #{session_attached}' \
        2>/dev/null)
done

echo "Killed $KILLED session(s)."
