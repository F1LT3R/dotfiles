#!/bin/bash
input=$(cat)
echo "$input" > /tmp/statusline-debug.json

# --- Data from Claude Code ---
MODEL=$(echo "$input" | jq -r '.model.display_name // "Claude"')
CWD=$(echo "$input" | jq -r '.workspace.current_dir // .cwd // ""')
PCT=$(echo "$input" | jq -r '.context_window.used_percentage // empty')

# --- Colors (no \[ \] wrappers needed outside PS1) ---
reset=$'\033[0m'
bold_green='\033[01;32m'
bold_red='\033[01;31m'
bold_yellow='\033[01;33m'
bold_blue='\033[01;34m'
bold_magenta='\033[01;35m'

# --- user@host (matches PS1: green user, reset @, red host) ---
USER_HOST=$(printf "${bold_green}%s${reset}@${bold_red}%s${reset}" "$(whoami)" "$(hostname -s)")

# --- path_prompt: parent in blue, last segment in yellow ---
path_prompt() {
    local dir="${CWD:-$HOME}" home="$HOME" parent base
    if [[ "$dir" == "$home" ]]; then
        printf "${bold_yellow}~${reset}"
    else
        parent="${dir%/*}"
        base="${dir##*/}"
        parent="${parent/#$home/\~}"
        printf "${bold_blue}%s/${bold_yellow}%s${reset}" "$parent" "$base"
    fi
}

# --- git_prompt: branch + status flags, color-coded ---
git_prompt() {
    local git_dir
    git_dir=$(git -C "$CWD" rev-parse --git-dir 2>/dev/null) || return 0

    local branch
    branch=$(git -C "$CWD" symbolic-ref --short HEAD 2>/dev/null \
             || git -C "$CWD" describe --tags --always 2>/dev/null) || return 0

    local status_output
    status_output=$(git -C "$CWD" --no-optional-locks status --porcelain 2>/dev/null)

    local has_staged=0 has_unstaged=0 has_untracked=0 has_conflicts=0
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local x="${line:0:1}" y="${line:1:1}"
        if   [[ "$x" == "U" || "$y" == "U" ]]; then has_conflicts=1
        elif [[ "$x" == "?" && "$y" == "?" ]]; then has_untracked=1
        else
            [[ "$x" != " " ]] && has_staged=1
            [[ "$y" != " " ]] && has_unstaged=1
        fi
    done <<< "$status_output"

    local ahead=0 behind=0
    local upstream
    upstream=$(git -C "$CWD" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null) || upstream=""
    if [[ -n "$upstream" ]]; then
        read -r ahead behind < <(git -C "$CWD" rev-list --left-right --count 'HEAD...@{u}' 2>/dev/null)
    fi

    local symbol="⊢ $branch"
    local flags=""

    (( has_conflicts )) && flags+=" ✖"
    (( has_unstaged  )) && flags+=" ✚"
    (( has_staged    )) && flags+=" ●"
    (( has_untracked )) && flags+=" …"

    if   (( ahead > 0 && behind > 0 )); then flags=" ⇅$flags"
    elif (( ahead > 0 ));               then flags=" ↑$flags"
    elif (( behind > 0 ));              then flags=" ↓$flags"
    fi

    local info="${symbol}${flags}"

    # Color: magenta=conflicts, yellow=changes, red=untracked, green=clean
    local color='\033[1;32m'
    [[ "$info" == *✖* ]] && color='\033[1;35m'
    [[ "$info" == *✚* || "$info" == *●* ]] && color='\033[1;33m'
    [[ "$info" == *…* ]] && color='\033[1;31m'

    printf "${color}%s${reset}" "$info"
}

# --- Color ramp: green → yellow → orange → red ---
color_ramp() {
    local pct=$1
    if   (( pct >= 85 )); then printf '\033[1;31m'
    elif (( pct >= 70 )); then printf '\033[38;5;208m'
    elif (( pct >= 50 )); then printf '\033[1;33m'
    else                       printf '\033[1;32m'
    fi
}

# --- Weekly usage from Anthropic via Airlock socket ---
SOCK="$HOME/.claude/.airlock/anthropic.sock"
WK_PCT="/tmp/claude-statusline-wk.pct"
WK_BACKOFF="/tmp/claude-statusline-wk.backoff"
WK_LOCK="/tmp/claude-statusline-wk.lock"
WK_TTL=300

# Background worker — fetches + writes .pct file
_wk_refresh() {
    local now hdr_file http_code body
    now=$(date +%s)
    # Backoff check
    if [[ -f "$WK_BACKOFF" ]]; then
        local bo_mtime bo_val
        bo_mtime=$(stat -f %m "$WK_BACKOFF" 2>/dev/null)
        bo_val=$(<"$WK_BACKOFF")
        (( now - bo_mtime < bo_val )) && return
    fi
    # One fetch at a time
    mkdir "$WK_LOCK" 2>/dev/null || return
    hdr_file="/tmp/claude-statusline-wk.hdr"
    body=$(curl -s --max-time 4 \
        --unix-socket "$SOCK" \
        -H "Accept: application/json" \
        -H "Content-Type: application/json" \
        -H "anthropic-beta: oauth-2025-04-20" \
        -H "User-Agent: claude-code-statusline/1.0.0" \
        -D "$hdr_file" \
        -w '\n%{http_code}' \
        http://localhost/api/oauth/usage 2>/dev/null)
    http_code="${body##*$'\n'}"
    body="${body%$'\n'*}"
    if [[ "$http_code" == "401" ]]; then
        exportclaude \
            ~/.airlock/projects/statusline/keys/ANTHROPIC_OAUTH_TOKEN \
            2>/dev/null
    elif [[ "$http_code" == "429" ]]; then
        local ra
        ra=$(grep -i '^retry-after:' "$hdr_file" \
            2>/dev/null | tr -d '\r' \
            | awk '{print $2}')
        echo "${ra:-60}" > "$WK_BACKOFF"
    elif [[ "$http_code" == "200" ]]; then
        rm -f "$WK_BACKOFF"
        local pct
        pct=$(echo "$body" \
            | jq -r '.weekly_usage_percent // empty' \
            2>/dev/null)
        [[ -n "$pct" ]] && echo "$pct" > "$WK_PCT"
    fi
    rm -f "$hdr_file"
    rmdir "$WK_LOCK" 2>/dev/null
}

wk_fetch() {
    if [[ "$STATUSLINE_WK" == "off" ]]; then return; fi
    if [[ ! -S "$SOCK" ]]; then return; fi
    # Kick off background refresh if stale
    local now
    now=$(date +%s)
    local needs_refresh=true
    if [[ -f "$WK_PCT" ]]; then
        local mtime
        mtime=$(stat -f %m "$WK_PCT" 2>/dev/null)
        (( now - mtime < WK_TTL )) && needs_refresh=false
    fi
    if $needs_refresh; then
        _wk_refresh &
        disown
    fi
    # Hot path: read plain text, no jq
    [[ -f "$WK_PCT" ]] && cat "$WK_PCT"
}

# --- Combined usage indicator [C10% | W12%] ---
usage_indicator() {
    local parts=()

    if [[ -n "$PCT" ]]; then
        local ci="${PCT%%.*}"
        local cc
        cc=$(color_ramp "$ci")
        parts+=("$(printf "%sC%d%%%s" "$cc" "$ci" "$reset")")
    fi

    # TODO: re-enable once rate limit clears
    # local wk
    # wk=$(wk_fetch)
    # if [[ -n "$wk" ]]; then
    #     local wi="${wk%%.*}"
    #     local wc
    #     wc=$(color_ramp "$wi")
    #     parts+=("$(printf "%sW%d%%%s" "$wc" "$wi" "$reset")")
    # fi

    if (( ${#parts[@]} > 0 )); then
        local joined="${parts[0]}"
        local i
        for (( i=1; i<${#parts[@]}; i++ )); do
            joined+=" | ${parts[$i]}"
        done
        printf " [%s]" "$joined"
    fi
}

# --- Assemble output ---
# Line 1: user@host  path  git  [C% | W%]  model
PATH_PART=$(path_prompt)
GIT_PART=$(git_prompt)
USAGE_PART=$(usage_indicator)

printf "${USER_HOST} ${PATH_PART}"
[[ -n "$GIT_PART" ]] && printf " ${GIT_PART}"
printf "%s" "${USAGE_PART}"
printf " ${bold_magenta}%s${reset}\n" "$MODEL"
